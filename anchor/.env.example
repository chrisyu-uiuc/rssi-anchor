# Unique anchor identifier (A1-A6)
ANCHOR_ID=A1

# Position of this anchor in the deployment area (cm)
ANCHOR_POSITION_X=0
ANCHOR_POSITION_Y=490

# Central server URL (Mac laptop IP)
SERVER_URL=http://192.168.1.100:3000

# Optional: filter for a specific target iBeacon
# Leave empty to report all iBeacons
TARGET_BEACON_UUID=
TARGET_MAJOR=
TARGET_MINOR=

# BLE scan restart interval (ms)
SCAN_INTERVAL=1000
